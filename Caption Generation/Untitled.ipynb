    "import pyarrow.parquet as pq\n",
    "\n",
    "pf = pq.ParquetFile(\"images_new.parquet\")\n",
    "\n",
    "for batch in pf.iter_batches(batch_size=10):\n",
    "    df = batch.to_pandas()\n",
    "print(df.head())"
